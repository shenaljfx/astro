# Server Environment Variables
PORT=3000
# NODE_ENV MUST be "production" on real deployments — nearly every fail-closed
# security guard (JWT length, webhook auth, admin secret, CORS restriction)
# engages only when NODE_ENV=production. The server refuses to boot if a real
# RevenueCat webhook key is present but NODE_ENV is not production.
NODE_ENV=development

# Trust proxy — set to the number of proxy/LB hops in front of the app (e.g. 1
# behind a single nginx/Cloudflare) so IP rate limiting sees the real client IP.
# Leave UNSET when the app is exposed directly (trusting X-Forwarded-For then
# lets clients spoof their IP to dodge rate limits).
# TRUST_PROXY=1

# OpenAI / Gemini API Key (replace with your actual key)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key (alternative AI provider)
GEMINI_API_KEY=your_gemini_api_key_here

# AI Provider: "openai" or "gemini"
# This app runs 100% on Gemini — keep this "gemini" so nothing ever falls back
# to an (unconfigured) OpenAI path and bills unexpectedly.
AI_PROVIDER=gemini

# Gemini standard model for chat, Porondam reports, and standard report sections
GEMINI_MODEL=gemini-2.5-flash

# Gemini Pro Model (optional, for hero report sections — e.g. gemini-2.5-pro)
# Falls back to standard model if not set or if Pro request fails
GEMINI_PRO_MODEL=

# Gemini 3.1 Pro Preview — for highest quality report generation with Google Search grounding
# Used for weekly lagna reports and full reading endpoints
# Falls back to GEMINI_PRO_MODEL if not set
GEMINI_3_PRO_MODEL=

# ── AI cost controls (2026-07 optimisation) ─────────────────────────
# Which full-report sections use the expensive Gemini 3.1 Pro model (comma-sep).
# Fewer = cheaper. Default (unset) = lifePredictions,surpriseInsights,marriage,career.
# GEMINI_HERO_SECTIONS=lifePredictions,surpriseInsights,marriage,career
# Thinking-token budgets (thinking bills as OUTPUT — the biggest lever on cost).
GEMINI_HERO_THINKING_BUDGET=4096
GEMINI_SECTION_THINKING_BUDGET=1024
GEMINI_COHERENCE_THINKING_BUDGET=2048
GEMINI_CHAT_THINKING_BUDGET=1024

# TimeZoneDB API Key — resolves the EXACT historical UTC offset for any lat/lng/timestamp.
# Critical for birth charts: wrong timezone = wrong Lagna (Ascendant).
# Free tier: unlimited requests (1 req/sec). Register at https://timezonedb.com/register
TIMEZONEDB_API_KEY=your_timezonedb_key_here

# Mock payments — set to 'true' to bypass subscription checks during dev
# ⚠ NEVER enable in production (server will refuse to start)
# MOCK_PAYMENTS=true

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be >= 32 chars. Required in production.
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Google OAuth Web Client ID — for verifying Android native Google Sign-In tokens
# Required in production. Get from Google Cloud Console → Credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here

# RevenueCat webhook auth key — set in RevenueCat Dashboard → Integrations → Webhooks
# Required in production. Without it, anyone can forge subscription events.
REVENUECAT_WEBHOOK_AUTH_KEY=your_revenuecat_webhook_auth_key_here

# Production alert webhook (Slack/Discord/Google Chat/custom webhook that accepts JSON)
# Leave blank locally. Set in production to receive 5xx, latency, memory, report, webhook, and AI spend alerts.
ALERT_WEBHOOK_URL=
ALERT_THROTTLE_MS=300000
ALERT_LATENCY_MS=30000
ALERT_MEMORY_RSS_MB=450
ALERT_DAILY_AI_SPEND_LKR=5000

# Durable Firestore-backed worker jobs
WORKER_POLL_MS=5000
START_EMBEDDED_WORKER=false
JOB_TTL_MS=604800000
JOB_LOCK_MS=600000
REPORT_PROGRESS_TTL_MS=86400000
VIBE_LINK_TTL_MS=604800000

# Distributed Firestore-backed limits and budget enforcement
DISTRIBUTED_AI_USER_PER_MINUTE=8
DISTRIBUTED_REPORT_USER_PER_HOUR=2
DAILY_GLOBAL_AI_SPEND_LIMIT_LKR=10000
DAILY_USER_AI_SPEND_LIMIT_LKR=700
AI_COST_EVENT_TTL_MS=7776000000
# Per-event AI cost doc sampling (fix F6). Rare/expensive features are always
# logged; cheaper features only when a single call costs >= this many LKR.
# The daily spend counters are always written, so totals stay exact.
AI_COST_EVENT_MIN_LKR=2

# ── Notification scheduler (fixes F1 & F2) ──────────────────────────
# Scheduler recipient list is cached in memory; the expensive token↔profile
# read runs at most once per this interval instead of ~4×/minute.
NOTIFICATION_RECIPIENT_CACHE_MS=600000
# Per-day dedupe markers + notification history retention (fix F3/F5).
NOTIFICATION_DEDUPE_TTL_MS=259200000
NOTIFICATION_LOG_TTL_MS=7776000000
# Leader election so only ONE instance runs scheduled ticks (fix F2).
# Set SCHEDULER_SINGLE_INSTANCE=true to skip the Firestore lease on a
# guaranteed single-instance/self-hosted deployment.
SCHEDULER_SINGLE_INSTANCE=false
SCHEDULER_LEASE_MS=90000
SCHEDULER_RENEW_MS=30000

# Paywall funnel event retention (fix F3)
PAYWALL_EVENT_TTL_MS=15552000000

# ── REQUIRED: Firestore TTL policies (fix F3) ───────────────────────
# Every collection below now writes a native `ttlExpireAt` Timestamp. Firestore
# only auto-deletes on a Timestamp field, so create a TTL policy on the field
# named `ttlExpireAt` for EACH of these collections (Firebase console →
# Firestore → TTL, or `gcloud firestore fields ttls update`):
#   jobs, rateLimits, dailyAiSpend, dailyAiUserSpend, aiCostEvents,
#   revenuecatWebhookEvents, reportProgress, vibeLinks, notifications,
#   notificationDedupe, paywallEvents, schedulerLocks
# Without these policies the documents are written but never auto-deleted.

# RevenueCat replay/de-duplication windows
REVENUECAT_WEBHOOK_MAX_AGE_MS=259200000
REVENUECAT_WEBHOOK_EVENT_TTL_MS=7776000000

# Subscription unit economics assumptions
SUBSCRIPTION_REVENUE_LKR=280
SUBSCRIPTION_REVENUE_USD=4.99
SUBSCRIPTION_PLATFORM_FEE_RATE=0.15
UNIT_CHAT_MESSAGES_PER_USER_PER_DAY=5
UNIT_CHAT_COST_LKR=1.25
UNIT_REPORTS_PER_USER_MONTH=1
# Real measured full-report AI cost (see benchmark/LIVE_AI_COST_REPORT.md):
# ~370 LKR before the 2026-07 optimisations, ~150-180 after. 200 is a realistic
# post-optimisation planning figure. It was previously 80 — a 4.6x under-count
# that made report unit economics look far healthier than reality.
UNIT_REPORT_COST_LKR=200
UNIT_RETRY_RATE=0.08
UNIT_SUPPORT_REGENERATION_RATE=0.03
UNIT_ACTIVE_SUBSCRIBERS=100
UNIT_WEEKLY_LAGNA_MONTHLY_COST_LKR=1500
UNIT_SUPPORT_TICKETS_PER_USER_MONTH=0.02
UNIT_SUPPORT_COST_PER_TICKET_LKR=150
UNIT_INFRA_SHARE_LKR=20

# Firestore backup automation
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_BACKUP_BUCKET=your-firestore-backup-bucket
FIRESTORE_BACKUP_PREFIX=firestore
