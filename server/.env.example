# Server Environment Variables
PORT=3000
NODE_ENV=development

# OpenAI / Gemini API Key (replace with your actual key)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key (alternative AI provider)
GEMINI_API_KEY=your_gemini_api_key_here

# AI Provider: "openai" or "gemini"
AI_PROVIDER=openai

# Gemini Pro Model (optional, for hero report sections — e.g. gemini-2.5-pro)
# Falls back to standard model if not set or if Pro request fails
GEMINI_PRO_MODEL=

# TimeZoneDB API Key — resolves the EXACT historical UTC offset for any lat/lng/timestamp.
# Critical for birth charts: wrong timezone = wrong Lagna (Ascendant).
# Free tier: unlimited requests (1 req/sec). Register at https://timezonedb.com/register
TIMEZONEDB_API_KEY=your_timezonedb_key_here
