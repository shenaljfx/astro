{
  "expo": {
    "name": "Grahachara",
    "slug": "grahachara",
    "version": "1.9.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "grahachara",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0B2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.grahachara.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to calculate accurate auspicious times based on your GPS coordinates."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0B2E"
      },
      "package": "com.grahachara.app",
      "versionCode": 90,
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "com.android.vending.BILLING",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#030014"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C3AED",
          "defaultChannel": "default"
        }
      ],
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Grahachara to save your forecast images to your gallery.",
          "savePhotosPermission": "Allow Grahachara to save your forecast images to your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "usesCleartextTraffic": true,
            "edgeToEdgeEnabled": false,
            "useLegacyPackaging": false
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1a77f887-0ff3-4a43-b4cc-5f48d6d60f74"
      }
    },
    "owner": "shenaldev"
  }
}
