    nativeBlobs: [
      { color: [244, 114, 182], x: 0.2, y: 0.1, size: 0.9 },
      { color: [219, 39, 119], x: 0.75, y: 0.35, size: 0.75 },
      { color: [232, 121, 249], x: 0.4, y: 0.6, size: 0.6 },
    ],
  },
  // PROFILE: Astral Projection — ice-blue stars, indigo auroras
  astral: {
    bg: 0x030510, fogColor: 0x030510,
    starTint: [0.5, 0.75, 1.0],
    nebulae: [
      { x: -280, y: 190, z: -490, size: 440, color: [76, 201, 240] },
      { x: 330, y: -110, z: -570, size: 380, color: [59, 130, 246] },
      { x: 30, y: -230, z: -540, size: 480, color: [99, 102, 241] },
