    auroras: [
      { color1: [0.15, 0.85, 1.0], color2: [0.1, 0.95, 0.7], color3: [0.3, 0.6, 1.0], opacity: 0.50, y: 105 },
      { color1: [0.2, 0.9, 0.85], color2: [0.05, 0.8, 0.65], color3: [0.4, 0.7, 1.0], opacity: 0.35, y: 85 },
      { color1: [0.1, 0.7, 0.95], color2: [0.25, 0.85, 0.9], color3: [0.15, 0.5, 0.8], opacity: 0.22, y: 120 },
