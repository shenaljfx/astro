    ],
    auroras: [
      { color1: [0.15, 0.85, 0.55], color2: [0.08, 0.7, 0.8], color3: [0.2, 0.5, 0.3], opacity: 0.42, y: 100 },
      { color1: [0.1, 0.75, 0.45], color2: [0.3, 0.9, 0.6], color3: [0.05, 0.6, 0.7], opacity: 0.28, y: 80 },
    ],
