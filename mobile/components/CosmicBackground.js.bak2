    nativeGrad: ['#030A08', '#041210', '#030A08'],
    nativeBlobs: [
      { color: [52, 211, 153], x: 0.25, y: 0.08, size: 0.85 },
      { color: [5, 150, 105], x: 0.7, y: 0.4, size: 0.7 },
