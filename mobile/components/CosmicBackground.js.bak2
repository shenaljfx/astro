// CosmicBackground.js — Variant-aware 3D WebGL cosmic backgrounds
// Each page variant gets a UNIQUE 3D scene: different nebula, aurora, star colors
// WEB: Full Three.js WebGL scene driven by variant
// NATIVE: LinearGradient + Reanimated fallback
import React, { useEffect, useRef } from 'react';
import { StyleSheet, View, Platform, Dimensions } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import Animated, {
  useSharedValue, useAnimatedStyle, withRepeat, withTiming,
