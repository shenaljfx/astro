  // MATCH: Twin Stars — pink-rose stars, magenta auroras
  pinkblue: {
    bg: 0x0A030A, fogColor: 0x0A030A,
    starTint: [1.0, 0.5, 0.8],
    nebulae: [
      { x: -300, y: 160, z: -480, size: 460, color: [244, 114, 182] },
      { x: 350, y: -90, z: -560, size: 400, color: [219, 39, 119] },
      { x: 0, y: -210, z: -530, size: 500, color: [232, 121, 249] },
