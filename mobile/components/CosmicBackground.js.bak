// CosmicBackground.js — Full 3D WebGL cosmos
// WEB: Three.js WebGL scene (milky way, star fields, nebula, aurora)
// NATIVE: dark View fallback with variant-specific cosmic overlays
import React, { useEffect, useRef, useMemo } from 'react';
import { StyleSheet, View, Platform, Dimensions } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import Animated, {
  useSharedValue, useAnimatedStyle, withRepeat, withTiming,
  withSequence, withDelay, Easing, interpolate,
} from 'react-native-reanimated';

var { width: SCREEN_W, height: SCREEN_H } = Dimensions.get('window');

