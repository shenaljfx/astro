/**
 * PaywallScreen — Custom Grahachara Paywall (replaces RevenueCat default UI)
 * 
 * A stunning cosmic-themed paywall with:
 * - Animated hero illustration (orbiting planets + zodiac ring)
 * - Feature list with staggered entry animations
 * - Plan selector (Monthly / Yearly with savings badge)
 * - Pulsing CTA button with glow
 * - Restore Purchases + Terms/Privacy links (App Store requirement)
 * - Full i18n support (English / Sinhala)
 * 
 * Usage:
 *   <PaywallScreen visible={true} onClose={fn} onPurchased={fn} />
 */

import React, { useState, useEffect, useCallback } from 'react';
import {
  View, Text, TouchableOpacity, StyleSheet, Modal, StatusBar,
  Dimensions, ActivityIndicator, ScrollView, Linking, Platform,
} from 'react-native';
import { useSafeAreaInsets } from 'react-native-safe-area-context';
import { Ionicons } from '@expo/vector-icons';
import { LinearGradient } from 'expo-linear-gradient';
import Animated, {
  FadeInDown, FadeInUp, FadeIn, FadeOut, ZoomIn, SlideInUp,
  useSharedValue, useAnimatedStyle, withRepeat, withTiming,
  withSpring, withDelay, withSequence, interpolate, Easing,
  interpolateColor, runOnJS,
} from 'react-native-reanimated';
import Svg, { Circle, Defs, LinearGradient as SvgGrad, Stop, Path, G, Ellipse } from 'react-native-svg';
import { Colors, Spacing, BorderRadius, Shadows, Typography, Gradients } from '../constants/theme';
import { boxShadow, textShadow } from '../utils/shadow';
import { useLanguage } from '../contexts/LanguageContext';
import { usePricing } from '../contexts/PricingContext';
import {
  getOfferings,
  purchasePackage,
  restorePurchases,
  checkEntitlement,
} from '../services/revenuecat';

var { width: SW, height: SH } = Dimensions.get('window');
var AnimatedLinearGradient = Animated.createAnimatedComponent(LinearGradient);

