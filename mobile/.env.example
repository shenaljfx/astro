# Firebase Client Configuration
# Get these from Firebase Console → Project Settings → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:placeholder

# Server API URL (override auto-detection if needed).
# Leave unset to auto-detect (localhost in dev, https://api.grahachara.com in prod builds).
# Set explicitly to force an environment — overrides ALL environments incl. dev:
# EXPO_PUBLIC_API_URL=https://api.grahachara.com
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Mock payments — set to 'true' to bypass RevenueCat purchases during dev
# EXPO_PUBLIC_MOCK_PAYMENTS=true
