rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function ownsProgressDoc() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    match /charts/{chartId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    match /chatSessions/{sessionId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    match /porondamResults/{resultId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    match /reportFeedback/{feedbackId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    match /reportProgress/{reportId} {
      allow read: if ownsProgressDoc();
      allow write: if false;
    }

    match /vibeLinks/{linkId} {
      allow read: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow write: if false;
    }

    // User-owned data. Currently only read server-side via the Admin SDK,
    // but keyed on `uid` so an owner-read rule is safe if a client read is
    // ever added. Writes stay server-only.
    match /predictionOutcomes/{outcomeId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    match /purchaseCredits/{creditId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if ownsExistingDoc();
      allow write: if false;
    }

    // Shared weekly horoscopes (no user PII). Readable by any signed-in
    // client; previously world-readable via `if true`.
    match /weeklyLagnaReports/{weekId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Server-only: internal ops, analytics, quotas, and device tokens.
    // No client ever touches these; listed explicitly for intent.
    match /jobs/{jobId} {
      allow read, write: if false;
    }

    match /rateLimits/{counterId} {
      allow read, write: if false;
    }

    match /dailyAiSpend/{dateId} {
      allow read, write: if false;
    }

    match /dailyAiUserSpend/{counterId} {
      allow read, write: if false;
    }

    match /aiCostEvents/{eventId} {
      allow read, write: if false;
    }

    match /revenuecatWebhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /promptAnalytics/{reportId} {
      allow read, write: if false;
    }

    match /pushTokens/{uid} {
      allow read, write: if false;
    }

    match /chatQuota/{uid} {
      allow read, write: if false;
    }

    match /proFairUse/{docId} {
      allow read, write: if false;
    }

    match /paywallEvents/{eventId} {
      allow read, write: if false;
    }

    match /dailyCosts/{docId} {
      allow read, write: if false;
    }

    match /schedulerLocks/{lockId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}