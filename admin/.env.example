# Grahachara Marketing Admin - Environment Variables
# Copy this to .env.local and fill in your values

# Gemini API Key (same one from server/.env)
GEMINI_API_KEY=your_gemini_api_key_here

# Server URL (your astrology API)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Pexels API Key (free at https://www.pexels.com/api/)
# Optional — if missing, reels use CSS-only element-themed backgrounds
PEXELS_API_KEY=your_pexels_api_key_here
